@model QLCuaHAngTienLoi.ViewModels.ThemSPVM

@{
    ViewData["Title"] = "Index";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #f4f6f9;
    }

    .layout {
        display: flex;
        height: 100vh;
    }

  

            .sidebar a:hover {
                background: rgba(255,255,255,0.2);
            }

    /* CONTENT */
    .content {
        flex: 1;
        padding: 40px;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        max-width: 600px;
        margin: auto;
    }

    h2 {
        text-align: center;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 5px;
    }

    input, select {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ccc;
        outline: none;
        transition: 0.2s;
    }

        input:focus, select:focus {
            border-color: #2a5298;
            box-shadow: 0 0 5px rgba(42,82,152,0.3);
        }

    button {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #36d1dc, #5b86e5);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 16px;
        cursor: pointer;
        transition: 0.3s;
    }

        button:hover {
            opacity: 0.9;
        }

    .success {
        color: green;
        text-align: center;
        margin-bottom: 10px;
    }

    .error {
        color: red;
        margin-bottom: 10px;
    }
</style>

<div class="layout">

    <!-- SIDEBAR -->
    @await Html.PartialAsync("_Sidebar")


    <!-- CONTENT -->
    <div class="content">
        <div class="card">
            <h2>Thêm sản phẩm</h2>

            @if (TempData["success"] != null)
            {
                <div class="success">@TempData["success"]</div>
            }

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="error"></div>

                <div class="form-group">
                    <label>Tên sản phẩm</label>
                    <input asp-for="SanPham.TenSanPham" />
                </div>

                <div class="form-group">
                    <label>Danh mục</label>
                    <select asp-for="SanPham.MaDanhMuc" asp-items="Model.DanhMucList" required>
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Nhà cung cấp</label>
                    <select asp-for="SanPham.MaNcc" asp-items="Model.NCCList" required>
                        <option value="">-- Chọn NCC --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Giá nhập</label>
                    <input id="giaNhap" asp-for="SanPham.GiaNhap" type="number" required />
                </div>

                <div class="form-group">
                    <label>Giá bán</label>
                    <input id="giaBan" asp-for="SanPham.GiaBan" readonly />
                </div>

                <div class="form-group">
                    <label>Số Lượng Nhập</label>
                    <input asp-for="SanPham.TonKho" type="number" />
                </div>

                <div class="form-group">
                    <label>Mức cảnh báo</label>
                    <input asp-for="SanPham.MucCanhBao" type="number" />
                </div>

                <button type="submit">Thêm sản phẩm</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const giaNhap = document.getElementById("giaNhap");
        const giaBan = document.getElementById("giaBan");

        giaNhap.addEventListener("input", function () {
            let value = parseFloat(this.value) || 0;
            giaBan.value = Math.round(value * 1.3);
        });
    });
</script>