@model QLCuaHAngTienLoi.ViewModels.TongQuanVM

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon products">📦</div>
        <div class="stat-info">
            <h3>Tổng sản phẩm</h3>
            <p class="stat-value">@Model.TongSanPham</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon revenue">💵</div>
        <div class="stat-info">
            <h3>Giá trị tồn kho</h3>
            <p class="stat-value">@Model.TongGiaTriTonKho.ToString("N0")đ</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon alerts">⚠️</div>
        <div class="stat-info">
            <h3>Sắp hết hàng</h3>
            <p class="stat-value">@Model.SanPhamSapHet</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon favorites">❤️</div>
        <div class="stat-info">
            <h3>Danh mục</h3>
            <p class="stat-value">@Model.TongDanhMuc</p>
        </div>
    </div>
</div>


<div class="sections-grid">

    <!-- SẢN PHẨM MỚI -->
    <div class="section">
        <div class="section-header">
            <h3>Sản phẩm mới thêm</h3>
            <a asp-controller="SanPhams" asp-action="Index" class="link">Xem tất cả</a>
        </div>

        <div class="products-list">

            @if (Model.RecentProducts == null || !Model.RecentProducts.Any())
            {
                <div class="empty-state">Không có sản phẩm mới</div>
            }
            else
            {
                @foreach (var p in Model.RecentProducts)
                {
                    <div class="product-item">

                        <div class="product-avatar">
                            @( !string.IsNullOrEmpty(p.TenSanPham) ? p.TenSanPham[0].ToString().ToUpper() : "?" )
                        </div>

                        <div class="product-details">
                            <p class="product-name">
                                <a asp-controller="SanPhams"
                                   asp-action="Details"
                                   asp-route-id="@p.MaSanPham">
                                    @p.TenSanPham
                                </a>
                            </p>

                            <p class="product-category">@p.Category</p>
                        </div>

                        <div class="product-card-price">
                            @p.Price.ToString("N0")đ
                        </div>

                    </div>
                }
            }

        </div>
    </div>


    <!-- CẢNH BÁO TỒN KHO -->
    <div class="section">
        <div class="section-header">
            <h3>⚠️ Cảnh báo tồn kho</h3>
            <a asp-controller="TonKho" asp-action="Index" class="link">Xem tất cả</a>
        </div>

        <div id="low-stock-alert">

            @if (Model.LowStockItems == null || !Model.LowStockItems.Any())
            {
                <div class="empty-state">Không có cảnh báo</div>
            }
            else
            {
                <div class="low-stock-list">

                    @foreach (var item in Model.LowStockItems)
                    {
                        var statusClass =
                        item.TonKho < 25 ? "critical"
                        : (item.TonKho < 40 ? "warning" : "normal");

                        <div class="alert-item">

                            <span>@item.TenSanPham</span>

                            <span class="stock-badge @statusClass">
                                @item.TonKho cái
                            </span>

                        </div>
                    }

                </div>
            }

        </div>
    </div>

</div>


<style>

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 20px;
        margin-bottom: 20px;
    }

    .stat-card {
        background: white;
        padding: 18px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .stat-icon {
        font-size: 28px;
    }

    .stat-value {
        font-size: 20px;
        font-weight: 600;
    }



    .sections-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .section {
        background: linear-gradient(145deg,#ffffff,#f8fafc);
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
    }



    .section-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
    }

    .link {
        font-size: 13px;
        color: #3b82f6;
    }



    .products-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-height: 260px; /* chiều cao card */
        overflow-y: auto; /* bật scroll */
        padding-right: 6px;
    }



        /* SCROLLBAR */

        .products-list::-webkit-scrollbar {
            width: 6px;
        }

        .products-list::-webkit-scrollbar-thumb {
            background: #cbd5f5;
            border-radius: 10px;
        }

            .products-list::-webkit-scrollbar-thumb:hover {
                background: #a5b4fc;
            }



    .product-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px;
        border-radius: 14px;
        background: white;
        border: 1px solid #f1f5f9;
    }



    .product-avatar {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg,#6366f1,#8b5cf6);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }



    .product-details {
        flex: 1;
    }

    .product-name a {
        font-weight: 600;
        text-decoration: none;
        color: #111827;
    }

    .product-category {
        font-size: 12px;
        color: #6b7280;
    }



    .product-card-price {
        font-weight: bold;
        color: #10b981;
        background: #ecfdf5;
        padding: 6px 12px;
        border-radius: 20px;
    }



    .low-stock-list {
        max-height: 260px;
        overflow-y: auto;
    }



    .alert-item {
        display: flex;
        justify-content: space-between;
        padding: 12px;
        border-radius: 12px;
        background: #f9fafb;
        margin-bottom: 10px;
    }



    .stock-badge {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 12px;
    }



        .stock-badge.normal {
            background: #e0f2fe;
            color: #0284c7;
        }

        .stock-badge.warning {
            background: #fef3c7;
            color: #d97706;
        }

        .stock-badge.critical {
            background: #fee2e2;
            color: #dc2626;
        }



    .empty-state {
        text-align: center;
        padding: 20px;
        color: #9ca3af;
    }
</style>