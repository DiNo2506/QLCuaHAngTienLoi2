@model QLCuaHAngTienLoi.ViewModels.ProductListVM
@using System.Globalization

@functions {
    private static string JsEscape(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        return s.Replace("\\", "\\\\").Replace("'", "\\'").Replace("\"", "\\\"");
    }
}

<div class="page-container">

    <!-- LEFT -->
    <div class="left-content">
        <div class="products-table-wrapper">

            <h2 class="title">📦 Danh sách sản phẩm</h2>

            <table class="products-table">
                <thead>
                    <tr>
                        <th>Tên sản phẩm</th>
                        <th>Nhà cung cấp</th>
                        <th>Mã</th>
                        <th>Danh mục</th>
                        <th>Giá</th>
                        <th>Tồn</th>
                        <th>Ngày</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model?.Items == null || !Model.Items.Any())
                    {
                        <tr>
                            <td colspan="8" class="empty-state">Không có sản phẩm</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var p in Model.Items)
                        {
                            var badge = p.Stock == 0 ? "out"
                            : p.Stock < 25 ? "critical"
                            : p.Stock < 45 ? "warning"
                            : "good";

                            var id = JsEscape(p.MaSanPham);
                            var name = JsEscape(p.TenSanPham);
                            var price = p.Price.ToString(CultureInfo.InvariantCulture);
                            var date = p.NgayThem?.ToString("dd/MM/yyyy") ?? "";

                            <tr>
                                <td><strong>@p.TenSanPham</strong></td>
                                <td class="company">@p.Company</td>
                                <td>@p.MaSanPham</td>
                                <td>@p.Category</td>
                                <td class="price">@p.Price.ToString("N0")đ</td>
                                <td><span class="stock-badge @badge">@p.Stock</span></td>
                                <td>@date</td>
                                <td>
                                    <button class="add-to-cart-btn"
                                            onclick="addToCart('@id','@name',@price)"
                                            @(p.Stock == 0 ? "disabled" : "")>
                                        @(p.Stock == 0 ? "Hết" : "Thêm")
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        @if (Model != null && Model.TotalPages > 1)
        {
            var current = Model.Page;
            var total = Model.TotalPages;

            <nav class="pagination">
                <ul class="pagination-list">

                    <li class="@(current == 1 ? "disabled" : "")">
                        <a href="?page=@(current - 1)">‹</a>
                    </li>

                    @for (int i = 1; i <= total; i++)
                    {
                        <li class="@(i == current ? "active" : "")">
                            <a href="?page=@i">@i</a>
                        </li>
                    }

                    <li class="@(current == total ? "disabled" : "")">
                        <a href="?page=@(current + 1)">›</a>
                    </li>

                </ul>
            </nav>
        }
    </div>

    <!-- RIGHT CART -->
    <div class="right-cart">
        @await Html.PartialAsync("_Cart")
    </div>

</div>

<style>
    /* ===== PAGE ===== */
    .page-container {
        display: grid;
        grid-template-columns: 2.5fr 1fr;
        gap: 20px;
        padding: 20px;
        background: linear-gradient(135deg,#eef2ff,#f8fafc);
        min-height: 100vh;
    }

    /* ===== TABLE CARD ===== */
    .products-table-wrapper {
        background: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.06);
    }

    .title {
        margin-bottom: 15px;
    }

    /* ===== TABLE ===== */
    .products-table {
        width: 100%;
        border-collapse: collapse;
    }

        .products-table th {
            padding: 12px;
            color: #64748b;
        }

        .products-table td {
            padding: 14px;
            border-top: 1px solid #f1f5f9;
        }

        .products-table tr:hover {
            background: #f9fafb;
            transform: translateY(-2px);
        }

    /* ===== TEXT ===== */
    .company {
        color: #64748b;
    }

    .price {
        color: #16a34a;
        font-weight: bold;
    }

    /* ===== BADGE ===== */
    .stock-badge {
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 12px;
    }

    .good {
        background: #dcfce7;
        color: #166534;
    }

    .warning {
        background: #fef3c7;
        color: #92400e;
    }

    .critical {
        background: #fee2e2;
        color: #991b1b;
    }

    .out {
        background: #e5e7eb;
    }

    /* ===== BUTTON ===== */
    .add-to-cart-btn {
        padding: 7px 14px;
        border-radius: 8px;
        border: none;
        background: linear-gradient(135deg,#6366f1,#4f46e5);
        color: white;
        cursor: pointer;
    }

        .add-to-cart-btn:hover {
            transform: translateY(-2px);
        }

    /* ===== CART ===== */
    .right-cart {
        position: sticky;
        top: 20px;
    }

    /* ===== PAGINATION ===== */
    .pagination {
        margin-top: 20px;
        text-align: center;
    }

    .pagination-list {
        display: inline-flex;
        gap: 6px;
        list-style: none;
    }

        .pagination-list a {
            padding: 8px 12px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

    .active a {
        background: #4f46e5;
        color: white;
    }
</style>

<script>
       window.addToCart = function (id, name, price) {

        const pid = String(id);
        const pname = String(name);
        const pprice = Number(price) || 0;

        // dùng hàm của _Cart
        let cart = window.__cartLoad();

        const idx = cart.findIndex(x => String(x.id) === pid);

        if (idx >= 0) {
            cart[idx].qty += 1;
        } else {
            cart.push({
                id: pid,
                name: pname,
                price: pprice,
                qty: 1
            });
        }

        window.__cartSave(cart);

        // 🔥 QUAN TRỌNG: render lại ngay
        window.__cartRender();

        // toast
        showCartToast(pname + " đã thêm vào giỏ");
    };

    // toast
    function showCartToast(message) {
        let toast = document.createElement("div");
        toast.innerText = message;
        toast.style.position = "fixed";
        toast.style.bottom = "20px";
        toast.style.right = "20px";
        toast.style.background = "#111";
        toast.style.color = "#fff";
        toast.style.padding = "10px 14px";
        toast.style.borderRadius = "8px";
        document.body.appendChild(toast);

        setTimeout(() => toast.remove(), 1500);
    }
</script>