@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var isTonKho = currentController.Equals("TonKho", System.StringComparison.OrdinalIgnoreCase)
                   || currentController.Equals("SanPhams", System.StringComparison.OrdinalIgnoreCase);
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .sidebar {
        width: 260px;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        background: linear-gradient(180deg, #1e3c72, #2a5298);
        color: white;
        padding: 20px 15px;
        box-shadow: 4px 0 15px rgba(0,0,0,0.1);
    }

    /* LOGO */
    .store-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .logo-img {
        width: 100px;
        height: 100px;
        object-fit: contain;
        border-radius: 20px;
        background: white;
        padding: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        .logo-img:hover {
            transform: scale(1.05);
        }

    .store-name {
        font-size: 16px;
        margin-top: 10px;
    }

    .sidebar-menu {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 15px;
        border-radius: 12px;
        text-decoration: none;
        color: white;
        cursor: pointer;
        transition: 0.25s;
    }

        .menu-item:hover {
            background: rgba(255,255,255,0.15);
            transform: translateX(5px);
        }

        .menu-item.active {
            background: white;
            color: #2a5298;
            font-weight: 600;
        }

    /* GROUP */
    .menu-group {
        display: flex;
        flex-direction: column;
    }

    .arrow {
        margin-left: auto;
        transition: 0.3s;
    }

    .submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .menu-group.open .submenu {
        max-height: 200px;
    }

    .menu-group.open .arrow {
        transform: rotate(180deg);
    }

    .menu-subitem {
        padding: 10px 15px;
        margin-left: 20px;
        border-radius: 10px;
        text-decoration: none;
        color: white;
        font-size: 14px;
        transition: 0.2s;
    }

        .menu-subitem:hover {
            background: rgba(255,255,255,0.15);
        }

        .menu-subitem.active {
            background: white;
            color: #2a5298;
            font-weight: 600;
        }
</style>

<aside class="sidebar">

    <!-- LOGO -->
    <div class="store-header">
        <img src="/images/logo.png" alt="Logo" class="logo-img" />
        <div class="store-name">Phó Cơ Điều,Phường 3, Vỉnh Long</div>
    </div>

    <nav class="sidebar-menu">

        <a asp-controller="TongQuan" asp-action="Index"
           class="menu-item @(currentController == "TongQuan" ? "active" : "")">
            📊 Tổng quan
        </a>

        <a asp-controller="SanPham" asp-action="Index"
           class="menu-item @(currentController == "SanPham" ? "active" : "")">
            🛒 Sản phẩm
        </a>

        <!-- Dropdown -->
        <div class="menu-group @(isTonKho ? "open" : "")">

            <div class="menu-item" onclick="toggleMenu(this)">
                 📦 Kho Hàng
                <span class="arrow">▼</span>
            </div>

            <div class="submenu">

                <a asp-controller="TonKho" asp-action="Index"
                   class="menu-subitem @(currentController == "TonKho" ? "active" : "")">
                    📋 Danh sách kho
                </a>

                <a asp-controller="SanPhams" asp-action="Create"
                   class="menu-subitem @(currentController == "SanPhams" && currentAction == "Create" ? "active" : "")">
                    ➕ Thêm sản phẩm
                </a>

            </div>
        </div>

        <a asp-controller="BaoCao" asp-action="Index"
           class="menu-item @(currentController == "BaoCao" ? "active" : "")">
            📈 Báo cáo
        </a>

    </nav>

</aside>

<script>
    function toggleMenu(element) {
        const group = element.parentElement;
        group.classList.toggle("open");
    }
</script>