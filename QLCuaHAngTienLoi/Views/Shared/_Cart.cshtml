<aside class="cart-sidebar">
    <div class="cart-header">
        <h3>🛒 Giỏ hàng</h3>
        <span class="cart-count" id="cart-count">0</span>
    </div>

    <div class="cart-items" id="cart-items">
        <div class="cart-empty">Giỏ hàng trống</div>
    </div>

    <div class="cart-summary">
        <div class="summary-row">
            <span>Số lượng:</span>
            <span id="cart-qty">0</span>
        </div>

        <div class="summary-row">
            <span>Tổng tiền:</span>
            <span class="summary-total" id="cart-total">0đ</span>
        </div>

        <button class="checkout-btn" id="checkout-btn" disabled>
            Thanh toán
        </button>
    </div>
</aside>

<style>
    /* ===== SIDEBAR ===== */
    .cart-sidebar {
        background: white;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    /* ===== HEADER ===== */
    .cart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .cart-count {
        background: #4f46e5;
        color: white;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 12px;
    }

    /* ===== ITEMS ===== */
    .cart-items {
        max-height: 300px;
        overflow-y: auto;
        margin-bottom: 15px;
    }

    .cart-empty {
        text-align: center;
        color: #94a3b8;
        padding: 20px;
    }

    /* ===== ITEM ===== */
    .cart-item {
        border-bottom: 1px solid #eee;
        padding: 10px 0;
    }

    .cart-item-name {
        font-weight: 600;
    }

    .cart-item-price {
        color: #16a34a;
        font-size: 13px;
    }

    /* ===== CONTROLS ===== */
    .cart-item-controls {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-top: 6px;
    }

    .qty-btn {
        padding: 3px 8px;
        border: none;
        background: #6366f1;
        color: white;
        border-radius: 6px;
        cursor: pointer;
    }

    .remove-btn {
        padding: 3px 8px;
        border: none;
        background: #ef4444;
        color: white;
        border-radius: 6px;
        cursor: pointer;
    }

    /* ===== INPUT ===== */
    .cart-qty-input {
        width: 45px;
        text-align: center;
        border: 1px solid #ddd;
        border-radius: 6px;
    }

    /* ===== SUMMARY ===== */
    .cart-summary {
        border-top: 1px solid #eee;
        padding-top: 10px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .summary-total {
        color: #16a34a;
        font-weight: bold;
    }

    /* ===== BUTTON ===== */
    .checkout-btn {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg,#22c55e,#16a34a);
        color: white;
        font-weight: 600;
        cursor: pointer;
    }

        .checkout-btn:disabled {
            background: #cbd5f5;
            cursor: not-allowed;
        }
</style>

<script>
    (function(){

        const CHECKOUT_PATH = '/HoaDon/Checkout';

        // ===== GLOBAL FUNCTIONS (để Products gọi được) =====
        window.__cartLoad = function(){
            try { return JSON.parse(localStorage.getItem('cart') || '[]'); }
            catch { return []; }
        };

        window.__cartSave = function(cart){
            localStorage.setItem('cart', JSON.stringify(cart));
        };

        window.__cartRender = function(){

            const cart = __cartLoad();

            const container = document.getElementById('cart-items');
            const count = document.getElementById('cart-count');
            const qty = document.getElementById('cart-qty');
            const total = document.getElementById('cart-total');
            const checkoutBtn = document.getElementById('checkout-btn');

            if(!cart.length){
                container.innerHTML = '<div class="cart-empty">Giỏ hàng trống</div>';
                count.textContent = '0';
                qty.textContent = '0';
                total.textContent = '0đ';
                checkoutBtn.disabled = true;
                return;
            }

            const totalQty = cart.reduce((s,i)=> s + i.qty,0);
            const totalPrice = cart.reduce((s,i)=> s + i.price*i.qty,0);

            count.textContent = totalQty;
            qty.textContent = totalQty;
            total.textContent = new Intl.NumberFormat('vi-VN').format(totalPrice)+'đ';

            checkoutBtn.disabled = false;

            container.innerHTML = cart.map(item=>{

                const price = new Intl.NumberFormat('vi-VN').format(item.price)+'đ';

                return `
                <div class="cart-item" data-id="${item.id}">
                    <div class="cart-item-name">${item.name}</div>
                    <div class="cart-item-price">${price}</div>

                    <div class="cart-item-controls">
                        <button class="qty-btn" data-action="dec">−</button>

                        <input type="number"
                               class="cart-qty-input"
                               value="${item.qty}"
                               min="1"
                               data-id="${item.id}">

                        <button class="qty-btn" data-action="inc">+</button>

                        <button class="remove-btn" data-action="remove">X</button>
                    </div>
                </div>
                `;
            }).join('');
        };

        // ===== CLICK =====
        document.addEventListener('click',function(e){

            const itemEl = e.target.closest('.cart-item');
            if(!itemEl) return;

            const id = itemEl.dataset.id;
            const action = e.target.dataset.action;

            if(!action) return;

            let cart = __cartLoad();
            const idx = cart.findIndex(x=>String(x.id)===String(id));

            if(idx === -1) return;

            if(action === 'inc') cart[idx].qty++;
            else if(action === 'dec'){
                cart[idx].qty--;
                if(cart[idx].qty <= 0) cart.splice(idx,1);
            }
            else if(action === 'remove'){
                cart.splice(idx,1);
            }

            __cartSave(cart);
            __cartRender();
        });

        // ===== INPUT =====
        document.addEventListener('change',function(e){

            if(!e.target.classList.contains('cart-qty-input')) return;

            const id = e.target.dataset.id;
            let val = parseInt(e.target.value);

            if(isNaN(val) || val < 1) val = 1;

            let cart = __cartLoad();
            let item = cart.find(x=>String(x.id)===String(id));

            if(item) item.qty = val;

            __cartSave(cart);
            __cartRender();
        });

        // ===== CHECKOUT =====
        document.getElementById('checkout-btn')?.addEventListener('click',function(){

            const cart = __cartLoad();

            if(!cart.length){
                alert('Giỏ hàng trống!');
                return;
            }

            window.location.href = CHECKOUT_PATH;
        });

        document.addEventListener('DOMContentLoaded',__cartRender);
    })();
</script>