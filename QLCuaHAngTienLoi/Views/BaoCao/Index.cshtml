@model QLCuaHAngTienLoi.ViewModels.BaoCaoVM

@{
    ViewData["Title"] = "Index";
}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI';
        background: #f5f7fb;
    }

    .layout {
        display: flex;
    }

    /* SIDEBAR */
    .sidebar {
        width: 240px;
        height: 100vh;
        background: #0f7b5f;
        position: fixed;
    }

    /* MAIN */
    .main {
        margin-left: 240px;
        padding: 25px;
        width: 100%;
    }

    .title {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    /* FILTER */
    .filter {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

        .filter input {
            padding: 8px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

        .filter button {
            background: #0f7b5f;
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 8px;
        }

    /* KPI */
    .kpi {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 20px;
        margin-bottom: 20px;
    }

    /* CARD */
    .card {
        background: white;
        padding: 20px;
        border-radius: 14px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.05);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .value {
        font-size: 26px;
        font-weight: bold;
    }

    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    /* NCC CENTER */
    .ncc-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 20px;
    }

    .ncc-card {
        width: 70%;
    }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
        border-radius: 10px;
        overflow: hidden;
    }

    th, td {
        padding: 12px;
    }

    th {
        background: #f1f3f5;
        font-weight: 600;
    }

    /* ROW EFFECT */
    tr {
        transition: 0.2s;
    }

        tr:hover {
            background: #f9fbfc;
        }

    /* CĂN GIỮA */
    .text-center {
        text-align: center;
        font-weight: 500;
    }

    /* BONUS: tiền nổi bật */
    td:last-child {
        color: #0f7b5f;
        font-weight: 600;
    }
</style>

<div class="layout">

    <!-- SIDEBAR -->
    <div class="sidebar">
        @await Html.PartialAsync("_Sidebar")
    </div>

    <!-- MAIN -->
    <div class="main">

        <div class="title">📊 Dashboard</div>

        <!-- FILTER -->
        <form method="get" class="filter">
            <input type="date" name="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
            <input type="date" name="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
            <button>Xem</button>
        </form>

        <!-- KPI -->
        <div class="kpi">
            <div class="card">
                <div>💰 Doanh thu</div>
                <div class="value">@Model.DoanhThu.ToString("N0") đ</div>
            </div>

            <div class="card">
                <div>🧾 Số đơn</div>
                <div class="value">@Model.SoDon</div>
            </div>

            <div class="card">
                <div>📦 Sản phẩm</div>
                <div class="value">@Model.SoLuong</div>
            </div>
        </div>

        <!-- GRID -->
        <div class="grid">

            <!-- CHART -->
            <div class="card">
                <h3>📈 Doanh thu theo ngày</h3>
                <canvas id="chart"></canvas>
            </div>

            <!-- TOP -->
            <div class="card">
                <h3>🏆 Top sản phẩm</h3>
                <ul>
                    @foreach (var sp in Model.TopSanPhams)
                    {
                        <li>@sp.TenSanPham - <b>@sp.SoLuongBan</b></li>
                    }
                </ul>
            </div>

        </div>

        <!-- NHÀ CUNG CẤP -->
        <div class="ncc-wrapper">
            <div class="card ncc-card">

                <h3>🏢 Nhà cung cấp</h3>

                <table>
                    <thead>
                        <tr>
                            <th>Tên</th>
                            <th class="text-center">Số SP</th>
                            <th class="text-center">Giá trị</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var ncc in Model.NhaCungCaps)
                        {
                            <tr>
                                <td>@ncc.TenCongTy</td>
                                <td class="text-center">@ncc.SoSanPham</td>
                                <td class="text-center">@ncc.GiaTri.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>

    </div>
</div>

<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(x => x.Ngay)));
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData.Select(x => x.TongTien)));

    new Chart(document.getElementById('chart'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Doanh thu',
                data: data,
                fill: true,
                tension: 0.4,
                borderWidth: 2
            }]
        }
    });
</script>