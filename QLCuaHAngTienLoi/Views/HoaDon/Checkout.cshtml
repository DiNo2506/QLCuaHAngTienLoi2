@{
    ViewData["Title"] = "Thanh toán";
}

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #f5f7fa, #e4ecf7);
        height: 100vh;
    }

    .overlay {
        position: fixed;
        inset: 0;
        backdrop-filter: blur(6px);
        background: rgba(0,0,0,0.2);
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .checkout-card {
        width: 420px;
        max-height: 80vh;
        overflow-y: auto;
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from {
            transform: translateY(20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .checkout-card h2 {
        margin-top: 0;
        text-align: center;
        font-size: 22px;
    }

    .item {
        border-bottom: 1px solid #eee;
        padding: 12px 0;
        display: flex;
        justify-content: space-between;
        font-size: 14px;
    }

    .item-name {
        font-weight: 500;
    }

    .item-price {
        color: #666;
    }

    .total {
        margin-top: 15px;
        font-size: 16px;
        display: flex;
        justify-content: space-between;
        font-weight: bold;
    }

    /* Nút đặt hàng - XANH LÁ */
    #btn-order {
        width: 100%;
        margin-top: 20px;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(135deg, #28a745, #218838);
        color: white;
        font-size: 15px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.2s;
    }

        #btn-order:hover {
            opacity: 0.95;
            transform: scale(1.02);
            background: linear-gradient(135deg, #34d058, #28a745);
        }

        #btn-order:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

    /* Nút quay lại */
    #btn-back {
        width: 100%;
        margin-top: 10px;
        padding: 10px;
        border: 2px solid #28a745;
        border-radius: 10px;
        background: white;
        color: #28a745;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: 0.2s;
    }

        #btn-back:hover {
            background: #28a745;
            color: white;
        }

    .empty {
        text-align: center;
        color: #888;
        padding: 20px 0;
    }
</style>

<div class="overlay">
    <div class="checkout-card">

        <h2>🧾 Thanh toán</h2>

        <div id="checkout-list"></div>

        <div class="total">
            <span>Tổng tiền:</span>
            <span id="total-price">0đ</span>
        </div>

        <button id="btn-order">Thanh Toán</button>
        <button id="btn-back">Quay lại</button>

    </div>
</div>

<script>
    (function(){

        function loadCart(){
            try {
                return JSON.parse(localStorage.getItem('cart') || '[]');
            } catch {
                return [];
            }
        }

        function formatMoney(n){
            return new Intl.NumberFormat('vi-VN').format(n) + 'đ';
        }

        function render(){
            const cart = loadCart();
            const el = document.getElementById('checkout-list');
            const totalEl = document.getElementById('total-price');
            const btn = document.getElementById('btn-order');

            if(!el || !totalEl) return;

            if(cart.length === 0){
                el.innerHTML = `<div class="empty">🛒 Giỏ hàng trống</div>`;
                totalEl.textContent = "0đ";

                if(btn) btn.disabled = true; // 🔥 disable nếu rỗng
                return;
            }

            let total = 0;

            el.innerHTML = cart.map(i => {
                const price = i.price || 0;
                const qty = i.qty || 0;
                const t = price * qty;

                total += t;

                return `
                    <div class="item">
                        <div>
                            <div class="item-name">${i.name}</div>
                            <div class="item-price">${qty} x ${formatMoney(price)}</div>
                        </div>
                        <div><b>${formatMoney(t)}</b></div>
                    </div>
                `;
            }).join('');

            totalEl.textContent = formatMoney(total);

            if(btn) btn.disabled = false;
        }

        function setLoading(btn, isLoading){
            if(!btn) return;

            if(isLoading){
                btn.disabled = true;
                btn.dataset.oldText = btn.innerText;
                btn.innerText = "⏳ Đang xử lý...";
            } else {
                btn.disabled = false;
                btn.innerText = btn.dataset.oldText || "Thanh Toán";
            }
        }

        function init(){
            const btn = document.getElementById('btn-order');
            const btnBack = document.getElementById('btn-back');

            if(!btn){
                console.error("❌ Không tìm thấy nút btn-order");
                return;
            }

            /* 🔥 Nút thanh toán */
            btn.addEventListener('click', async function(){

                const cart = loadCart();

                if(cart.length === 0){
                    alert("Giỏ hàng trống!");
                    return;
                }

                setLoading(btn, true);

                try {
                    const res = await fetch('/HoaDon/CreateOrder', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },

                        // 🔥 FIX QUAN TRỌNG: gửi đúng format
                        body: JSON.stringify({
                            items: cart.map(i => ({
                                id: i.id,   // 🔥 BẮT BUỘC
                                qty: i.qty
                            }))
                        })
                    });

                    const data = await res.json();

                    if (!res.ok) {
                        throw new Error(data.error || data.detail || "Lỗi server");
                    }

                    alert("🎉 Đặt hàng thành công!");

                    localStorage.removeItem('cart');

                    window.location.href = '/HoaDon/Success?orderId=' + data.orderId;

                } catch (err) {
                    alert("❌ " + err.message);
                } finally {
                    setLoading(btn, false);
                }
            });

            /* 🔙 Nút quay lại */
            if (btnBack) {
                btnBack.addEventListener('click', function () {
                    window.location.href = '/SanPham'; // ổn định hơn history.back()
                });
            }

            render();
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", init);
        } else {
            init();
        }

    })();
</script>